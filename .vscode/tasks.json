{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tauri:dev",
      "type": "shell",
      "command": "npm run tauri dev",
      "options": {},
      "isBackground": true,
      "problemMatcher": {
        "owner": "rust",
        "fileLocation": ["relative", "${workspaceFolder}/src-tauri"],
        "pattern": {
          "regexp": "^error\\[.*\\]:\\s+(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Compiling.*",
          "endsPattern": ".*Finished.*|.*Running.*"
        }
      },
      "group": "build"
    },
    {
      "label": "tauri:build",
      "type": "shell",
      "command": "npm run tauri build",
      "options": {},
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo:check",
      "type": "shell",
      "command": "cargo check",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo:test",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "npm:test",
      "type": "shell",
      "command": "npm test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vite:dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*ready in.*|.*localhost.*"
        }
      },
      "group": "build"
    }
  ]
}
